# Datos persistentes de PostgreSQL (no deben versionarse)
docker/data/

# Variables de entorno y secretos
.env
.env.*
!.env.example
.streamlit/

# VS Code (configuración personal, no del proyecto)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# Claude Code (notas/config locales, no del proyecto)
.claude/CLAUDE.local.md
.claude/settings.local.json

# SQLTools (archivos de sesión, no del proyecto)
*.session.sql

# Sistema operativo
.DS_Store
Thumbs.db

# Logs
*.log
**/__pycache__/
*.pyc

# PDFs de exámenes oficiales (no versionar)
data/examenes/
