# Copiar este archivo como .env y rellenar los valores reales
# cp .env.example .env

# OpenAI — para generar embeddings de las preguntas (modo Q&A)
OPENAI_API_KEY=sk-...

# Anthropic — para que Claude genere respuestas y preguntas test
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL (valores por defecto del docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stack_db
DB_USER=postgres
DB_PASSWORD=postgres
